root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{sln,csproj,vbproj,vcxproj,vcproj,fsproj,props,targets,xml,resx,config,nuspec}]
end_of_line = crlf

[*.{json,jsonc,yml,yaml}]
indent_size = 2

[*.{js,ts,jsx,tsx,css,scss,html}]
indent_size = 2

[Makefile]
indent_style = tab
