# Consumer example — append to your app .npmrc (do not commit tokens).
#
# Replace OWNER with the GitHub user or org that publishes @query-grid/*.
#
# Local install (PAT with read:packages):
#   //npm.pkg.github.com/:_authToken=YOUR_GITHUB_PAT
#
# GitHub Actions (consuming repo):
#   NODE_AUTH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
#   (grant the workflow read access to the package — see publishing.md)

@query-grid:registry=https://npm.pkg.github.com
