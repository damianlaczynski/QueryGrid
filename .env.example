# QueryGrid release — copy to .env and fill in (never commit .env)

# ── GitHub ────────────────────────────────────────────────────────────────────
# PAT with repo + write:packages (local release script / gh CLI only; CI uses GITHUB_TOKEN)
GITHUB_TOKEN=
GITHUB_OWNER=damianlaczynski
GITHUB_REPO=QueryGrid

# ── npm (npmjs.com) ───────────────────────────────────────────────────────────
# Automation token with publish access to @query-grid/*
NPM_TOKEN=
NPM_TAG=preview

# ── NuGet.org — trusted publishing (recommended) ──────────────────────────────
# Profile name on nuget.org (NOT your email). Copy this value to GitHub repo secret NUGET_USER.
NUGET_USER=

# One-time setup on https://www.nuget.org → Account → Trusted Publishing:
#   Package Owner:     <your nuget.org account>
#   Repository Owner:  damianlaczynski
#   Repository:        QueryGrid
#   Workflow File:     publish.yml
#   Environment:       (leave empty unless you use GitHub Environment "release")
#
# Then add GitHub repo secret: NUGET_USER = same as above.
# CI exchanges OIDC token for a short-lived key via NuGet/login@v1 — no API key in secrets.

# ── NuGet.org — local push only (optional fallback) ───────────────────────────
# Classic API key from nuget.org → API Keys. Only needed for local `dotnet nuget push`
# without OIDC. CI does NOT use this when trusted publishing is configured.
# NUGET_ORG_API_KEY=
NUGET_ORG_SOURCE=https://api.nuget.org/v3/index.json

# ── GitHub Packages (optional local push) ─────────────────────────────────────
NUGET_GITHUB_URL=https://nuget.pkg.github.com/damianlaczynski/index.json
NUGET_GITHUB_USERNAME=damianlaczynski
NUGET_GITHUB_PASSWORD=

# ── Release behaviour (future release script) ─────────────────────────────────
RELEASE_CREATE_GITHUB_RELEASE=true
RELEASE_PRERELEASE=true
RELEASE_DRY_RUN=false
