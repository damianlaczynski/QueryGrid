# QueryGrid release — copy to .env (never commit .env)

# ── GitHub (optional — for npm run release links) ─────────────────────────────
GITHUB_OWNER=damianlaczynski
GITHUB_REPO=QueryGrid

# ── GitHub Actions secrets (add in repo Settings, NOT in .env for CI) ─────────
# NUGET_USER   = nuget.org profile name (not email)
# NPM_TOKEN    = npm automation token with publish access to @query-grid/*

# ── nuget.org trusted publishing (one-time on nuget.org) ─────────────────────
# Package Owner: damianlaczynski | Repository: QueryGrid | Workflow: publish.yml

# ── Local release script ──────────────────────────────────────────────────────
RELEASE_DRY_RUN=false
